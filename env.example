# Example
EXAMPLE_SERVICE_URL=http://example_service:51888

# Uvicorn
UVICORN_PORT=8000
# Enable auto-reload on source changes. Development only — leave false (or unset) in production.
UVICORN_RELOAD=false

# App
APP_LOGGING_LEVEL=DEBUG

# Jwt
JWT_SECRET=REPLACE_THIS_WITH_YOUR_OWN_SECRET_JWT_SECRET_VALUE

# Password
PASSWORD_PEPPER=REPLACE_THIS_WITH_YOUR_OWN_SECRET_PEPPER_VALUE

# Postgres
POSTGRES_DB=clean-example
POSTGRES_HOST=db_pg
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Redis — rate-limit backend (slowapi). In-network host is `redis`; host port is mapped via REDIS_PORT.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# SMTP (email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@yourapp.com
SMTP_USE_TLS=true

# Verification
VERIFICATION_CODE_TTL_MIN=10
VERIFICATION_RESEND_COOLDOWN_SEC=60

# CORS — comma-separated list of allowed origins (no trailing slashes)
CORS_ALLOWED_ORIGINS=http://localhost:3000
